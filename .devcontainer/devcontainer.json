{
  "name": "Jekyll GitHub Pages",
  "image": "mcr.microsoft.com/devcontainers/jekyll:2-bullseye",
  
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "forwardPorts": [4000],
  
  "postCreateCommand": "bundle install",
  
  "customizations": {
    "vscode": {
      "extensions": [
        "streetsidesoftware.code-spell-checker"
      ]
    }
  },

  "remoteUser": "vscode"
}
